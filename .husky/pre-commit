# husky v9 は内部で `sh -e` 起動するため実質的に既に有効だが、
# 単体実行や将来の起動経路変更でも安全側に倒すため明示する。
# (途中コマンドが失敗した場合は即時中断してコミットを成立させない)
set -e

bunx lint-staged

# --- Security: Prevent committing sensitive file paths ---
# 以下のパターンにマッチするファイル名が含まれている場合はコミットを拒否する。
# `--diff-filter=d` で「削除 (Deleted)」を除外: リスクは「機密ファイルがリポジトリに
# 含まれること」なので、すでにコミットされてしまった機密ファイルを `git rm` で
# 削除しようとした際にこのチェックでブロックされないようにする。
FORBIDDEN_FILES=$(git diff --cached --name-only --diff-filter=d | grep -E '(\.env.*|\.cursor/.*|\.claude/.*|\.aider.*|\.windsurf/.*|\.jules/.*|\.Jules/.*|.*credentials.*\.json|.*\.pem|.*\.key)$' || true)

if [ -n "$FORBIDDEN_FILES" ]; then
  echo "🚨 [Security Error] The following sensitive files are staged for commit:"
  echo "$FORBIDDEN_FILES"
  echo "Please unstage them using 'git restore --staged <file>' and ensure they are added to .gitignore."
  exit 1
fi
# ---------------------------------------------------------

# --- Security: Gitleaks scan for staged files ---
# コミットされるファイルの中身に対して gitleaks を実行し、APIキー等の混入を防ぐ。
# バイナリがインストールされていない場合はユーザーキャッシュに自動ダウンロードして実行する。
# オフライン環境・未対応OS/ARCH・チェックサム検証失敗時はローカルスキャンをスキップし、
# コミット自体はブロックしない（CIでの検知に委ねる）。
GITLEAKS_CMD="gitleaks"
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "⚠️  gitleaks is not installed globally. Downloading automatically..."
  GITLEAKS_VERSION="8.21.2"
  GITLEAKS_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/gitleaks"
  GITLEAKS_BIN="${GITLEAKS_CACHE_DIR}/gitleaks-${GITLEAKS_VERSION}"
  if [ ! -x "$GITLEAKS_BIN" ]; then
    OS=$(uname -s | tr '[:upper:]' '[:lower:]')
    ARCH=$(uname -m)
    if [ "$OS" = "linux" ] || [ "$OS" = "darwin" ]; then
      if [ "$ARCH" = "x86_64" ]; then
        ARCH="x64"
      elif [ "$ARCH" = "aarch64" ] || [ "$ARCH" = "arm64" ]; then
        ARCH="arm64"
      else
        echo "⚠️  Unsupported architecture for automatic download: $ARCH. Skipping local scan."
        GITLEAKS_CMD=""
      fi
      if [ -n "$GITLEAKS_CMD" ]; then
        TARBALL="gitleaks_${GITLEAKS_VERSION}_${OS}_${ARCH}.tar.gz"
        echo "Downloading ${TARBALL}..."
        TMP_DIR=$(mktemp -d)
        CHECKSUM_OK=0
        if curl -fsSL "https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/${TARBALL}" -o "$TMP_DIR/$TARBALL" && \
           curl -fsSL "https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/gitleaks_${GITLEAKS_VERSION}_checksums.txt" -o "$TMP_DIR/checksums.txt"; then
          sha256sum_cmd=""
          if command -v sha256sum >/dev/null 2>&1; then
            sha256sum_cmd="sha256sum"
          elif command -v shasum >/dev/null 2>&1; then
            sha256sum_cmd="shasum -a 256"
          fi
          if [ -n "$sha256sum_cmd" ]; then
            EXPECTED=$(grep "$TARBALL" "$TMP_DIR/checksums.txt" | awk '{print $1}')
            ACTUAL=$($sha256sum_cmd "$TMP_DIR/$TARBALL" | awk '{print $1}')
            if [ -n "$EXPECTED" ] && [ "$EXPECTED" = "$ACTUAL" ]; then
              CHECKSUM_OK=1
            else
              echo "⚠️  Checksum verification failed. Skipping local scan."
            fi
          else
            CHECKSUM_OK=1
          fi
        else
          echo "⚠️  Failed to download gitleaks. Skipping local scan for this commit."
        fi
        if [ "$CHECKSUM_OK" = "1" ]; then
          tar -xz -C "$TMP_DIR" -f "$TMP_DIR/$TARBALL" gitleaks
          mkdir -p "$GITLEAKS_CACHE_DIR"
          chmod 700 "$GITLEAKS_CACHE_DIR"
          mv "$TMP_DIR/gitleaks" "$GITLEAKS_BIN"
          chmod +x "$GITLEAKS_BIN"
        else
          GITLEAKS_CMD=""
        fi
        rm -rf "$TMP_DIR"
      fi
    else
      echo "⚠️  Unsupported OS for automatic download: $OS. Skipping local scan."
      GITLEAKS_CMD=""
    fi
  fi
  if [ -n "$GITLEAKS_CMD" ] && [ -x "$GITLEAKS_BIN" ]; then
    GITLEAKS_CMD="$GITLEAKS_BIN"
  fi
fi

if [ -n "$GITLEAKS_CMD" ]; then
  echo "🔍 Running gitleaks on staged files..."
  # `--staged`: ステージされたファイルのみをスキャン対象とする
  # `--redact`: ターミナル出力でシークレットの生値をマスクする
  # `--no-banner`: 起動時のアスキーアートバナーを抑制し pre-commit 出力を簡潔に保つ
  "$GITLEAKS_CMD" protect --staged --redact --verbose --no-banner || exit 1
fi
# ---------------------------------------------------------

# .github/workflows/ がステージされていれば actionlint をローカルで実行
# (actionlint がインストールされていない環境はスキップして CI 側で拾う)
changed_workflows=$(git diff --cached --name-only --diff-filter=ACMR -- '.github/workflows/' || true)
if [ -n "$changed_workflows" ]; then
  if command -v actionlint >/dev/null 2>&1; then
    echo "🔍 Running actionlint on staged workflows..."
    # ローカル環境で actionlint が外部呼び出し待ちでハングする事例があるため
    # 60s で打ち切り、CI 側に委ねる (macOS は gtimeout = coreutils 経由)
    timeout_cmd=""
    if command -v timeout >/dev/null 2>&1; then
      timeout_cmd="timeout 60s"
    elif command -v gtimeout >/dev/null 2>&1; then
      timeout_cmd="gtimeout 60s"
    fi
    # actionlint の `-shellcheck` 既定値は `"shellcheck"` (PATH 探索)。
    # ローカルに shellcheck が無い環境では actionlint が起動時にエラー終了して
    # コミット全体をブロックするため、明示的に空指定で integration を無効化。
    shellcheck_opt="-shellcheck="
    if command -v shellcheck >/dev/null 2>&1; then
      shellcheck_opt="-shellcheck=$(command -v shellcheck)"
    fi
    # `-no-color` は macOS ローカルで actionlint がハングする回避策
    # (一部環境で color 出力初期化が詰まる事例あり、CI 側は -color で別途実行)
    # NOTE: husky v9 は `sh -e` で hook を起動するため、actionlint が non-zero
    # で返るとその場で hook が死ぬ。`|| rc=$?` で exit を捕捉してから自分で
    # 判定・分岐する。失敗しなかった場合は `rc` 未設定なので `${rc:-0}` で補完。
    rc=0
    # shellcheck disable=SC2086
    $timeout_cmd actionlint -no-color $shellcheck_opt $changed_workflows || rc=$?
    if [ "$rc" -ne 0 ]; then
      if [ "$rc" = "124" ]; then
        echo "⚠️  actionlint timed out locally (>60s) — skipping; CI will run the full check."
      else
        exit "$rc"
      fi
    fi
  else
    echo "ℹ️  actionlint not installed locally — workflow lint will run in CI only."
    echo "   Install: brew install actionlint  (macOS) or see https://github.com/rhysd/actionlint"
  fi
fi

# Run typecheck for changed workspaces
changed_backend=$(git diff --cached --name-only -- 'backend/src/')
changed_frontend=$(git diff --cached --name-only -- 'frontend/src/')

if [ -n "$changed_backend" ]; then
  echo "🔍 Running backend typecheck..."
  npm run typecheck --prefix backend
  echo "🧪 Running backend tests..."
  npm run test --prefix backend
fi

if [ -n "$changed_frontend" ]; then
  echo "🔍 Running frontend typecheck..."
  npm run typecheck --prefix frontend
  echo "🧪 Running frontend tests..."
  npm run test --prefix frontend
fi