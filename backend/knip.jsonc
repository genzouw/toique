{
  "$schema": "https://unpkg.com/knip@5/schema-jsonc.json",
  "project": ["src/**/*.ts"],
  "ignoreDependencies": [
    // esbuild は overrides 経由で再ピン留めしているだけで直接 import しない
    "esbuild"
  ],
  "rules": {
    "files": "error",
    "dependencies": "error",
    "unlisted": "error",
    "unresolved": "error",
    "exports": "warn",
    "types": "warn"
  }
}
