{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/main.tsx",
    "src/**/*.test.{ts,tsx}",
    "e2e/**/*.{ts,tsx}",
    "functions/**/*.{ts,js}",
    "scripts/**/*.mjs",
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "eslint.config.js"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "e2e/**/*.{ts,tsx}",
    "functions/**/*.{ts,js}",
    "scripts/**/*.mjs"
  ],
  "ignoreDependencies": [
    // Tailwind v4 は vite plugin 経由で利用、tailwind.config.* を持たないため誤検知される
    "tailwindcss",
    "tw-animate-css",
    // Cloudflare Pages の wrangler は CLI 用 (デプロイ workflow から呼ぶ)
    "wrangler"
  ]
}
