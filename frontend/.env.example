# 公開サイトのオリジン URL（末尾スラッシュなし）。
# canonical / OGP / sitemap / robots.txt の生成に使用される。
# vite.config.ts (loadEnv) と src/lib/site.ts (import.meta.env) の2箇所から参照され、
# 値が未設定の場合は各箇所のフォールバック値（同一値）が使われる。
VITE_SITE_ORIGIN=https://example.com

# 特定商取引法に基づく表記 (src/pages/Tokushoho.tsx) で参照される事業者情報。
# 未設定の場合は英語の placeholder ('Your Company Name' / 'Representative Name' /
# 'contact@example.com') が表示されるため、本番公開前に必ず実値を設定する。
VITE_COMPANY_NAME=Your Company Name
VITE_REPRESENTATIVE_NAME=Representative Name
VITE_CONTACT_EMAIL=contact@example.com
